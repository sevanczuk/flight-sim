<pre><b>hw_dial_id = hw_dial_add(hw_id_a, hw_id_b, callback)</b>
<b>hw_dial_id = hw_dial_add(hw_id_a, hw_id_b, type, callback)</b>
<b>hw_dial_id = hw_dial_add(hw_id_a, hw_id_b, acceleration, callback)</b>
<b>hw_dial_id = hw_dial_add(hw_id_a, hw_id_b, type, acceleration, callback)</b>
</pre>
<table class="wikitable">

<tbody><tr>
<th>#</th>
<th>Argument</th>
