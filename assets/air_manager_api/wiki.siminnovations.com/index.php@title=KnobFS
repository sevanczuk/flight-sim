<h2><span class="mw-headline" id="KnobFS">KnobFS</span></h2>
<p>KnobFS lets you use the Knobster within Microsoft Flight Simulator, both in normal mode and VR mode.
</p>
<div style="background: rgba(255, 0, 0, 0.1); border: solid thin grey; padding: 10px; display: flex; align-items: center;&#125;&#125;"><a href="/index.php?title=File:Warning.png" class="image" title="Info"><img alt="Info" src="/images/thumb/c/cb/Warning.png/18px-Warning.png" decoding="async" width="18" height="18" srcset="/images/thumb/c/cb/Warning.png/27px-Warning.png 1.5x, /images/thumb/c/cb/Warning.png/36px-Warning.png 2x" /></a> <span style="margin-top:-0px; padding-left:16px; display:block;">KnobFS is only compatible with the <a rel="nofollow" class="external text" href="https://www.siminnovations.com/shop/knobster/">Knobster V2</a> and Microsoft Flight Simulator 2020 &amp; 2024. It is <u>not</u> compatible with the old and the DIY Knobster.<br />
Do <u>not</u> install KnobFS if you want to use the Knobster with Air Manager or Air Player!</span></div>
<p><br />
<iframe width="560" height="315" src="//www.youtube-nocookie.com/embed/5jvMnJuFivY" frameborder="0" allowfullscreen=""></iframe>
</p>
<h2><span class="mw-headline" id="Download">Download</span></h2>
<pre><ul id="si_download_list" style="list-style: none; margin: 0; padding: 0;"></ul>
<script>
	const applicationMap = { "AIR_MANAGER" : "Air Manager", "AIR_PLAYER" : "Air Player" };
	
	const platformNameMap = {"LINUX": "Linux", "MAC": "Mac", "WINDOWS" : "Windows", "RASPBERRY_PI" : "Raspberry Pi", "ARDUINO" : "Arduino"};
	const platormOrderMap = [ "WINDOWS", "MAC", "LINUX", "RASPBERRY_PI", "ARDUINO" ];
	
	const architectureMap = {"X86_64" : "64-bit", "X86" : "32-bit", "ARM" : "ARM", "ARM64" : "ARM 64-bit", "ANY" : "" };
	const architectureOrderMap = [ "X86_64", "X86", "ARM", "ARM64", "ANY" ];

	const programCompilationMap = { "HOME_USE" : "Home Use", "PROFESSIONAL" : "Professional" };

	var api_version = "api6";
	var application_group_type = "KNOBFS";
	var program_compilation = "HOME_USE";
	var beta = false;
	
	if ( (api_version == null) || (api_version == "") ) {
		api_version = "api5";
	}
	
	const Http = new XMLHttpRequest();
	const url = 'https://' + api_version + '.siminnovations.com/application/all';
	Http.open("GET", url);
	Http.send();

	Http.onreadystatechange = (e) => {
		if (Http.readyState == 4) {
			const json = JSON.parse(Http.responseText);
			
			json.sort((a, b) => {
				var index_a = platormOrderMap.indexOf(a.platform);
				var index_b = platormOrderMap.indexOf(b.platform);
			
				if (index_a == index_b) {
					index_a = architectureOrderMap.indexOf(a.architecture);
					index_b = architectureOrderMap.indexOf(b.architecture);
				}
			
				return index_a - index_b;
			} );
			
			json.forEach(function(application) {
				if ( (application_group_type == "") || (application.application_group == application_group_type) ) {
					 if (application.program_compilation == program_compilation) {
						if (application.beta == beta) {
							if (application.platform != "RASPBERRY_PI") {
								var text = document.createElement('div');
								
								var innerHTML = application.name;
								
								if (application.beta) {
									innerHTML += " " + application.major + "." + application.minor + " " + programCompilationMap[program_compilation] + " (BETA " + application.build  + ")";
								}
								else {
									innerHTML += " " + application.major + "." + application.minor + "." + application.build + " " + programCompilationMap[program_compilation];
								}
								
								if (application.architecture) {
									innerHTML += " (" + (platformNameMap[application.platform] || application.platform) + " " + ( (architectureMap[application.architecture] || application.architecture) || ")") + ")";
								}
								
								text.innerHTML = innerHTML;
								text.style.flex = "1 0 0";
								text.style.padding = "14px";
								text.style.fontFamily = "sans-serif";
								text.style.fontSize = "14px";
								
								var button = document.createElement('BUTTON');
								button.style.flex = "0 0 auto";
								button.style.padding = "10px";
								button.style.margin = "4px";
								button.style.backgroundColor = "lightgray";					
								button.style.cursor = "pointer";
								button.style.fontFamily = "sans-serif";
								button.style.fontSize = "14px";
								button.onclick = function() {
									const ampersand = String.fromCharCode(38);
								
									const download_url = "https://" + api_version + ".siminnovations.com/application/download/" + application.uuid;
								
									const link = document.createElement("a");
									link.href = download_url;
									document.body.appendChild(link);
									link.click();
									document.body.removeChild(link);
								};
								button.appendChild(document.createTextNode("Download"));
								
								const parentDiv = document.createElement("div");
								parentDiv.style.display = "flex";
								parentDiv.style.backgroundColor = "#038fe828";
								parentDiv.appendChild(text);
								parentDiv.appendChild(button);
								
								var listNode = document.createElement('li');
								listNode.style = "border-style: solid; border-width: 1px;";
								listNode.appendChild(parentDiv);
								
								document.getElementById('si_download_list').appendChild(listNode);
							}
						}
					}
				}
			});
		}
	}
</script></pre>
<h2><span class="mw-headline" id="Installation">Installation</span></h2>
<div class="thumb tright"><div class="thumbinner" style="width:202px;"><a href="/index.php?title=File:Knobfs_window.jpg" class="image"><img alt="" src="/images/thumb/c/c0/Knobfs_window.jpg/200px-Knobfs_window.jpg" decoding="async" width="200" height="172" class="thumbimage" srcset="/images/thumb/c/c0/Knobfs_window.jpg/300px-Knobfs_window.jpg 1.5x, /images/thumb/c/c0/Knobfs_window.jpg/400px-Knobfs_window.jpg 2x" /></a>  <div class="thumbcaption"><div class="magnify"><a href="/index.php?title=File:Knobfs_window.jpg" class="internal" title="Enlarge"></a></div>The KnobFS menu within MSFS</div></div></div>
<div class="thumb tright"><div class="thumbinner" style="width:202px;"><a href="/index.php?title=File:Knobfs_mode_select.jpg" class="image"><img alt="" src="/images/thumb/9/99/Knobfs_mode_select.jpg/200px-Knobfs_mode_select.jpg" decoding="async" width="200" height="316" class="thumbimage" srcset="/images/thumb/9/99/Knobfs_mode_select.jpg/300px-Knobfs_mode_select.jpg 1.5x, /images/thumb/9/99/Knobfs_mode_select.jpg/400px-Knobfs_mode_select.jpg 2x" /></a>  <div class="thumbcaption"><div class="magnify"><a href="/index.php?title=File:Knobfs_mode_select.jpg" class="internal" title="Enlarge"></a></div>KnobFS settings window</div></div></div>
<p>1. Run the KnobFS installer.<br />
2. Start Microsoft Flight Simulator and once the aircraft is loaded you will see the KnobFS icon in the menu bar. Click the icon to open KnobFS.<br />
3. When in VR mode, you can position the KnobFS window to a convenient place in your cockpit with your VR controller.
</p>
<h2><span class="mw-headline" id="User_manual">User manual</span></h2>
<h3><span class="mw-headline" id="Control_modes">Control modes</span></h3>
<p>KnobFS comes with a list of pre-defined modes. These modes can be turned on and off from the KnobFS settings tab.<br />
In the KnobFS window click the sprocket/settings icon, this brings you to the settings tab, which allows you to turn modes on and off. These settings are stored uniquely for each different aircraft you fly.
</p><p>Each mode triggers different Microsoft Flight Simulator events.
Two examples:
</p>
<pre><b>Autopilot heading</b>
Outer dial: Autopilot heading up / down
Inner dial: Autopilot heading up / down
Button: Sync autopilot heading
</pre>
<pre><b>COM1 frequency</b>
Outer dial: COM1 frequency coarse up / down
Inner dial: COM1 frequency fine up / down
Button: COM1 standby flip
</pre>
<h3><span class="mw-headline" id="Active_mode">Active mode</span></h3>
<p>The active mode is visible within the blue box.
</p>
<h3><span class="mw-headline" id="Selecting_a_mode">Selecting a mode</span></h3>
<h4><span class="mw-headline" id="Voice">Voice</span></h4>
<p>If you have a microphone connected to your computer, then you can switch between modes by saying <i>Select</i> and the corresponding phrase. For example saying <i>Select COM</i> will set the selection to the COM1 frequency. You can also use the number that is displayed. Saying <i>Select 1</i> will also set the select mode to COM 1. The numbers and phrases are shown beneath the modes. You can turn off voice control in the KnobFS settings menu.
</p>
<h4><span class="mw-headline" id="Knobster_dial">Knobster dial</span></h4>
<p>When pressing and holding the Knobster button for half a second, KnobFS will go into selection mode, indicated by a green box. When in selection mode, both the inner and outer dial can be used to scroll through the list. Pressing the Knobster button again will select the mode in the green box.
</p>
<h4><span class="mw-headline" id="Mouse_and_VR_controller">Mouse and VR controller</span></h4>
<p>Selecting a mode can be done by pointing and clicking with your mouse or VR controller on the desired mode.
</p>
<h2><span class="mw-headline" id="Advanced_usage">Advanced usage</span></h2>
<div style="background: lightyellow; border: solid thin grey; padding: 10px; display: flex; align-items: center;&#125;&#125;"><a href="/index.php?title=File:Lightbulb.png" class="image" title="Info"><img alt="Info" src="/images/thumb/6/6f/Lightbulb.png/18px-Lightbulb.png" decoding="async" width="18" height="22" srcset="/images/thumb/6/6f/Lightbulb.png/27px-Lightbulb.png 1.5x, /images/thumb/6/6f/Lightbulb.png/36px-Lightbulb.png 2x" /></a> <span style="margin-top:-0px; padding-left:16px; display:block;">Adding or modifying a mode requires the KnobFS (Windows) service to be stopped and started.</span></div>
<p>You can create your own mode with a little JSON script. This allows for commands for custom add-on aircraft for example.
</p><p>Navigate to <i>C:\users\your username\KnobFS 202x\modes\</i><br />
There you will see all the available modes within a JSON file. These JSON files can be opened with a code editor like <a rel="nofollow" class="external text" href="https://notepad-plus-plus.org/">Notepad++</a>.<br />
Events can be found on either the official <a rel="nofollow" class="external text" href="https://docs.flightsimulator.com/html/Programming_Tools/Event_IDs/Event_IDs.htm">Microsoft SDK website</a>, or the <a rel="nofollow" class="external text" href="https://hubhop.mobiflight.com/">Mobiflight Hubhop</a> project website.
</p><p>Regular (K/keyboard) events require <i>&gt;K:</i> in front of the event name.
</p>
<pre><code class="json todo">{
    &quot;name&quot;: &quot;COM1 frequency&quot;,
    &quot;minor_cw_code&quot;:	&quot;(&gt;K:COM_RADIO_FRACT_INC)&quot;,
    &quot;minor_ccw_code&quot;:	&quot;(&gt;K:COM_RADIO_FRACT_DEC)&quot;,
    &quot;major_cw_code&quot;:	&quot;(&gt;K:COM_RADIO_WHOLE_INC)&quot;,
    &quot;major_ccw_code&quot;:	&quot;(&gt;K:COM_RADIO_WHOLE_DEC)&quot;,
    &quot;button_released_code&quot;: &quot;(&gt;K:COM1_RADIO_SWAP)&quot;,
    &quot;phrases&quot;&#160;: [
        &quot;Select 1&quot;, &quot;Select COM&quot;, &quot;Select COM 1 frequency&quot;, &quot;Select COM 1&quot;
    ],
    &quot;order&quot;: 100100
}</code></pre><script type="">if('hljsGo' in window) window.hljsGo();</script>
<p>The H events require <i>&gt;H:</i> in front of the event name.
</p>
<pre><code class="json todo">{
    &quot;name&quot;: &quot;G1000 CRS BARO&quot;,
    &quot;minor_cw_code&quot;:	&quot;(&gt;H:AS1000_PFD_CRS_INC)&quot;,
    &quot;minor_ccw_code&quot;:	&quot;(&gt;H:AS1000_PFD_CRS_DEC)&quot;,
    &quot;minor_acceleration&quot;: 20,
    &quot;major_cw_code&quot;:	&quot;(&gt;H:AS1000_PFD_BARO_INC)&quot;,
    &quot;major_ccw_code&quot;:	&quot;(&gt;H:AS1000_PFD_BARO_DEC)&quot;,
    &quot;button_released_code&quot;: &quot;(&gt;H:AS1000_PFD_CRS_PUSH)&quot;,
    &quot;phrases&quot;&#160;: [
        &quot;Select 22&quot;, &quot;Select course&quot;, &quot;Select baro&quot;, &quot;Select G1000 course&quot;, &quot;Select G1000 baro&quot;, &quot;Select G1000 pressure&quot;
    ],
    &quot;order&quot;: 101102
}</code></pre><script type="">if('hljsGo' in window) window.hljsGo();</script>
<p>KnobFS uses the so called 'executer code'. This allows you to perform more complicated actions if required.
</p>
<pre><code class="json todo">{
    &quot;name&quot;: &quot;Garmin G1000 AP altitude&quot;,
    &quot;minor_cw_code&quot;: &quot;(A:AUTOPILOT ALTITUDE LOCK VAR, feet) 100 + (&gt;K:AP_ALT_VAR_SET_ENGLISH) (&gt;H:AP_KNOB_Up)&quot;,
    &quot;minor_ccw_code&quot;: &quot;(A:AUTOPILOT ALTITUDE LOCK VAR, feet) 100 - (&gt;K:AP_ALT_VAR_SET_ENGLISH) (&gt;H:AP_KNOB_Up)&quot;,
    &quot;major_cw_code&quot;: &quot;(A:AUTOPILOT ALTITUDE LOCK VAR, feet) 1000 + (&gt;K:AP_ALT_VAR_SET_ENGLISH) (&gt;H:AP_KNOB_Up)&quot;,
    &quot;major_ccw_code&quot;: &quot;(A:AUTOPILOT ALTITUDE LOCK VAR, feet) 1000 - (&gt;K:AP_ALT_VAR_SET_ENGLISH) (&gt;H:AP_KNOB_Up)&quot;,
    &quot;button_released_code&quot;: &quot;(A:INDICATED ALTITUDE, feet) (&gt;K:AP_ALT_VAR_SET_ENGLISH) (&gt;H:AP_KNOB)&quot;,
    &quot;phrases&quot;&#160;: [
        &quot;Select 50&quot;, &quot;Autopilot altitude&quot;
    ],
    &quot;order&quot;: 501109
}</code></pre><script type="">if('hljsGo' in window) window.hljsGo();</script>
<p>An B-event example for the autopilot up and down in the 747-800 and possibly more aircraft.
</p>
<pre><code class="json todo">{
    &quot;name&quot;: &quot;Boeing 747-800 AP altitude&quot;,
    &quot;minor_cw_code&quot;: &quot;1 (&gt;B:AUTOPILOT_Altitude_Set)&quot;,
    &quot;minor_ccw_code&quot;: &quot;-1 (&gt;B:AUTOPILOT_Altitude_Set)&quot;,
    &quot;major_cw_code&quot;: &quot;1 (&gt;B:AUTOPILOT_Altitude_Set)&quot;,
    &quot;major_ccw_code&quot;: &quot;-1 (&gt;B:AUTOPILOT_Altitude_Set)&quot;,
    &quot;button_released_code&quot;: &quot;(A:INDICATED ALTITUDE, feet) (&gt;K:AP_ALT_VAR_SET_ENGLISH) (&gt;H:AP_KNOB)&quot;,
    &quot;phrases&quot;&#160;: [
        &quot;Select 150&quot;, &quot;Autopilot altitude&quot;
    ],
    &quot;order&quot;: 501209
}</code></pre><script type="">if('hljsGo' in window) window.hljsGo();</script>
<p>Create a new JSON file based on the same structure to create your own mode, and fill in your desired MSFS events.
</p>
<pre><i>name</i>                      The mode name that will show up within the KnobFS window
<i>minor_cw_code</i>             Inner dial clockwise code
<i>minor_ccw_code</i>            Inner dial counter clockwise code
<i>major_cw_code</i>             Outer dial clockwise code
<i>major_ccw_code</i>            Outer dial counter clockwise code
<i>order</i>                     This number determines in which position the mode will show up in the list, the lower the number the higher in the list
<i>phrases</i>                   These are the phrases that let you select a mode with voice control. You can choose whatever you prefer here, but try to keep it simple for better recognition.
<i>button_released_code</i>      Button event
<i>minor_acceleration</i>        Inner dial acceleration, 1 is no acceleration (optional)
<i>major_acceleration</i>        Outer dial acceleration, 1 is no acceleration (optional)
</pre>
