<h2><span class="mw-headline" id="Example">Example</span></h2>
<pre><code class="lua todo">-- Create a blue rectangle using canvas. (Note that in this case we use canvas, viewport_shape can be used on all node types like text, images, dial etc.)
canvas_id = canvas_add(0, 0, 200, 200, function()
  _rect(0, 0, 100, 100)
  _fill(&quot;blue&quot;)
end)

-- Define a shape in which we look at this blue box, in this case through a circle shape
viewport_shape(canvas_id, function()
    _circle(80, 80, 50)
end)</code></pre><script type="">if('hljsGo' in window) window.hljsGo();</script>
